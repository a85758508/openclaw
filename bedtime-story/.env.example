# ====================
# ElevenLabs (声音克隆)
# ====================
# 从 https://elevenlabs.io → Profile → API Keys 获取
ELEVENLABS_API_KEY=

# 克隆你的声音后，在 Voice Lab 里复制 Voice ID
ELEVENLABS_VOICE_ID=

# ====================
# Telegram Bot (可选)
# ====================
# 如果要用 Telegram 发送故事，填入 Bot Token
# 可以用现有的 OpenClaw Telegram Bot Token
TELEGRAM_BOT_TOKEN=

# ====================
# 其他配置
# ====================
# 你孩子的名字/小名（故事里会用，增加亲近感）
CHILD_NAME=逸珩

# 故事默认时长（秒）
DEFAULT_DURATION=180

# 输出目录
OUTPUT_DIR=output
